HOST=0.0.0.0
PORT=3000

# Public site URL (used for Discord OAuth redirect)
APP_URL=http://localhost:3000

# Session signing secret (use a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-string

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Optional override; defaults to APP_URL/auth/discord/callback
DISCORD_REDIRECT_URI=

# Launcher OAuth callback (PKCE); register this URI in Discord Developer Portal
LAUNCHER_REDIRECT_URI=http://127.0.0.1:47832/auth/callback

# JWT signing for launcher API access (defaults to SESSION_SECRET if unset)
JWT_SECRET=
JWT_ACCESS_TTL_SEC=3600
JWT_REFRESH_TTL_SEC=2592000

# Unlisted route for the launcher banned-addons list (obscure path; not linked from site)
# Override the default obscure segment with your own unguessable value.
LAUNCHER_BANLIST_ROUTE=/api/launcher/integrity/3f9a1c7d

# External MariaDB connection (hosted elsewhere — this app only connects to it)
DB_HOST=your-db-host.example.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_database

# Set to true if your MariaDB server requires SSL/TLS
DB_SSL=false

# Wiki API rate limiting (ms between external wiki requests)
WIKI_API_DELAY_MS=250
