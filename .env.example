PORT=3000

# External MariaDB connection (hosted elsewhere — this app only connects to it)
DB_HOST=your-db-host.example.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_database

# Set to true if your MariaDB server requires SSL/TLS
DB_SSL=false

# Wiki API rate limiting (ms between external wiki requests)
WIKI_API_DELAY_MS=250
