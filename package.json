{
  "name": "sanctum-site",
  "version": "0.1.0",
  "description": "Private FFXI server website with external MariaDB and live wiki aggregation",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch-path=src --watch-path=.env src/index.js",
    "zones:generate": "node scripts/generate-zones.js",
    "missions:generate": "node scripts/generate-missions.js",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "jose": "^6.2.3",
    "mariadb": "^3.4.0",
    "sanitize-html": "^2.17.5",
    "session-file-store": "^1.5.0"
  },
  "devDependencies": {
    "wrangler": "^4.105.0"
  }
}
